# =============================================================================
# EMT Field Assist — Environment Configuration
# Copy this file to .env and fill in values. Never commit .env with real keys.
# =============================================================================

# --- Server: Protocol Search ---
# Controls how the server searches for EMS protocol sources.
#   mock = curated index + mock web results (no external API calls)
#   web  = real web search via API (requires key + endpoint or legacy keys)
PROTOCOL_SEARCH_PROVIDER=mock

# Unified search API credentials (used when PROTOCOL_SEARCH_PROVIDER=web).
# The endpoint receives a GET request with ?q=<query> and should return JSON.
PROTOCOL_SEARCH_API_KEY=
PROTOCOL_SEARCH_ENDPOINT=

# Legacy per-provider keys (alternative to unified config above).
# If PROTOCOL_SEARCH_PROVIDER=web and no unified key/endpoint is set,
# the server falls back to these in order:
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CSE_ID=
# BING_SEARCH_API_KEY=
# SERPAPI_API_KEY=

# --- Server: General ---
PORT=3001

# --- Client: Backend URLs (prefix with VITE_ for Vite) ---
# When set, the client calls these instead of using local mock data.
# VITE_PROTOCOL_SEARCH_URL=http://localhost:3001/protocol-search
# VITE_PROTOCOL_IMPORT_URL=http://localhost:3001/protocol-import
